        "dados_historicos = yf.download(tickers_yf, start=str_inicio_yf, end=str_fim_yf)['Close']\n",
        "\n",
        "retornos_acoes = {}\n",
        "\n",
        "for ticker_yf in tickers_yf:\n",
        "    ticker_original = ticker_yf.replace('.SA', '')\n",
        "\n",
        "    try:\n",
        "        # Pega a coluna da ação e remove os dias sem negociação (NaN)\n",
        "        # Se for apenas um ticker, o yf retorna uma Series direta, tratamos isso:\n",
