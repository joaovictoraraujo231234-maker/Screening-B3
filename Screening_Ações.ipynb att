        "    # Validação de Diversificação Setorial\n",
        "    # Acessa 'Segmento' de df_final que contém essa informação\n",
        "    segmentos_carteira = df_final[df_final['Ticker da Ação'].isin(carteira_teste)]['Segmento']\n",
        "    if segmentos_carteira.value_counts().max() > MAX_POR_SETOR:\n",
        "        continue # Se tiver mais de 2 ações do mesmo setor, descarta a carteira\n",
        "\n",
        "    # Calcula o Risco/Correlação da Carteira\n",
        "    # Pega apenas o pedaço da matriz de correlação das ações sorteadas\n",
        "    sub_matriz = matriz_correlacao.loc[carteira_teste, carteira_teste]\n",
        "\n",
        "    # Extrai a correlação média (ignorando a diagonal principal que é 1.0)\n",
        "    valores_correlacao = sub_matriz.values[np.triu_indices_from(sub_matriz.values, k=1)]\n",
        "    correlacao_media = valores_correlacao.mean()\n",
        "\n",
        "    # Salva o resultado\n",
        "    carteiras_geradas.append({\n",
        "        'Tickers': carteira_teste,\n",
