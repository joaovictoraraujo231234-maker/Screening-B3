        "# =========================================================\n",
        "PESO_DIVIDENDOS = 0.60    # 60% em Large Caps (Vacas Leiteiras)\n",
        "PESO_CRESCIMENTO = 0.40   # 40% em Small/Mid Caps (Crescimento)\n",
        "QTD_ACOES = 12            # Tamanho da carteira desejada\n",
        "MAX_POR_SETOR = 2         # Limite máximo de ações do mesmo segmento\n",
        "TOP_N_CARTEIRAS = 5       # Quantas opções o algoritmo vai devolver\n",
        "SIMULACOES = 5000         # Número de carteiras geradas no Monte Carlo\n",
        "\n",
        "# =========================================================\n",
        "# 1. PREPARAÇÃO E RANKING QUALITATIVO\n",
        "# =========================================================\n",
        "print(\"Iniciando motor de otimização de portfólio...\")\n",
        "\n",
        "# Definimos as quantidades exatas\n",
        "qtd_large = int(QTD_ACOES * PESO_DIVIDENDOS)\n",
        "qtd_growth = QTD_ACOES - qtd_large\n",
        "\n",
        "# Separamos os universos\n",
        "df_large = df_filtrado[df_filtrado['Classificação'] == 'Large Cap'].copy()\n",
