        "# 1. PREPARAÇÃO DAS DATAS\n",
        "# =========================================================\n",
        "data_fim = datetime.today()\n",
        "data_inicio = data_fim - relativedelta(years=ANOS_BACKTEST)\n",
        "\n",
        "# Formatação para o Banco Central (DD/MM/YYYY) e Yahoo Finance (YYYY-MM-DD)\n",
        "str_inicio_bcb = data_inicio.strftime('%d/%m/%Y')\n",
        "str_fim_bcb = data_fim.strftime('%d/%m/%Y')\n",
        "\n",
        "str_inicio_yf = data_inicio.strftime('%Y-%m-%d')\n",
        "str_fim_yf = data_fim.strftime('%Y-%m-%d')\n",
        "\n",
        "print(f\"Calculando Retorno Total com reinvestimento de dividendos...\")\n",
        "print(f\"Período: {str_inicio_bcb} até {str_fim_bcb} ({ANOS_BACKTEST} anos)\\n\")\n",
        "\n",
        "# =========================================================\n",
        "# 2. PUXANDO O CDI ACUMULADO (API DO BANCO CENTRAL)\n",
        "# =========================================================\n",
        "def obter_cdi_acumulado(data_inicial, data_final):\n",
        "    # Código 12 no SGS do BCB é a Taxa CDI diária\n",
        "    url = f'http://api.bcb.gov.br/dados/serie/bcdata.sgs.12/dados?formato=json&dataInicial={data_inicial}&dataFinal={data_final}'\n",
        "    try:\n",
        "        response = requests.get(url)\n",
        "        df_cdi = pd.DataFrame(response.json())\n",
        "        df_cdi['valor'] = df_cdi['valor'].astype(float) / 100\n",
        "        # O cálculo exato do BCB é a produtória: Π (1 + taxa_diária) - 1\n",
        "        cdi_acumulado = (1 + df_cdi['valor']).prod() - 1\n",
        "        return cdi_acumulado\n",
        "    except Exception as e:\n",
        "        print(f\"Erro ao buscar CDI: {e}\")\n",
        "        return 0.0\n",
        "\n",
        "cdi_periodo = obter_cdi_acumulado(str_inicio_bcb, str_fim_bcb)\n",
