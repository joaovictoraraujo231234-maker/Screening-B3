        "# Renomeia as colunas de 'TICKER.SA' para 'TICKER' para cruzar com a nossa lista\n",
        "retornos_diarios.columns = [col.replace('.SA', '') for col in retornos_diarios.columns]\n",
        "\n",
        "# Calcula a matriz de correlação geral\n",
        "matriz_correlacao = retornos_diarios.corr()\n",
        "\n",
        "# ==========================================================\n",
        "# DESDUPLICAÇÃO DE TICKERS (Mantém apenas o de maior liquidez)\n",
        "# ==========================================================\n",
        "# 1. Cria uma coluna temporária com as 4 primeiras letras (ex: 'KLBN' de 'KLBN11')\n",
        "df_filtrado['Ticker_Base'] = df_filtrado.index.str[:4]\n",
        "\n",
        "# 2. Ordena tudo pela liquidez (da maior para a menor)\n",
        "df_filtrado = df_filtrado.sort_values(by='liq2m', ascending=False)\n",
        "\n",
        "# 3. Apaga as duplicatas baseadas nas 4 primeiras letras, mantendo apenas a primeira (que é a de maior liquidez)\n",
        "df_filtrado = df_filtrado.drop_duplicates(subset='Ticker_Base', keep='first')\n",
        "\n",
        "# 4. Remove a coluna temporária para não poluir sua planilha\n",
        "df_filtrado = df_filtrado.drop(columns=['Ticker_Base'])\n",
        "\n",
        "# Volta a ordenar pelo index (ordem alfabética dos tickers) para ficar organizado\n",
        "df_filtrado = df_filtrado.sort_index()\n",
