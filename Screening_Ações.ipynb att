        "\n",
        "# RANKING QUALITATIVO: Damos notas para as ações para o algoritmo priorizar as melhores\n",
        "# Para Large Caps: Queremos Alto DY e Alto ROE\n",
        "df_large['Score'] = df_large['dy'].rank(ascending=False) + df_large['roe'].rank(ascending=False)\n",
        "df_large = df_large.sort_values('Score').head(15) # Pegamos as 15 melhores para o sorteio\n",
        "\n",
        "# Para Growth (Mid/Small): Queremos Baixo P/L e Alto ROE\n",
        "df_growth['Score'] = df_growth['pl'].rank(ascending=True) + df_growth['roe'].rank(ascending=False)\n",
        "df_growth = df_growth.sort_values('Score').head(15) # Pegamos as 15 melhores para o sorteio\n",
        "\n",
